<%- include("../partials/header") %>

<h1>My Service Requests</h1>

<p><a href="/service/new">+ New Service Request</a></p>

<% if (requests.length === 0) { %>
  <p>You have no service requests yet.</p>
<% } else { %>
  <% requests.forEach(r => { %>
    <div style="border:1px solid #ccc; padding:12px; margin-bottom:12px;">
      <p><strong>#<%= r.request_id %> — <%= r.service_type %></strong></p>
      <p>
        <strong>Vehicle:</strong>
        <% if (r.year && r.make && r.model) { %>
          <%= r.year %> <%= r.make %> <%= r.model %>
        <% } else { %>
          Not specified
        <% } %>
      </p>
      <p><strong>Status:</strong> <%= r.status %></p>
      <% if (r.description) { %>
        <p><strong>Description:</strong> <%= r.description %></p>
      <% } %>
      <% if (r.notes) { %>
        <p><strong>Notes from staff:</strong> <%= r.notes %></p>
      <% } %>
      <p><strong>Submitted:</strong> <%= new Date(r.created_at).toLocaleDateString() %></p>
      <% if (r.updated_at && r.updated_at !== r.created_at) { %>
        <p><strong>Last updated:</strong> <%= new Date(r.updated_at).toLocaleDateString() %></p>
      <% } %>
    </div>
  <% }) %>
<% } %>

<%- include("../partials/footer") %>

<%- include("../partials/header") %>

<div class="admin-page-header">
  <h1 class="page-title"><%= title %></h1>
</div>

<% if (typeof errors !== "undefined" && errors.length > 0) { %>
  <div class="form-errors">
    <ul style="margin:0; padding-left:1.2rem;">
      <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
    </ul>
  </div>
<% } %>

<form action="/service/new" method="POST" class="service-form">

  <!-- Vehicle info: free-text -->
  <fieldset class="service-form-fieldset">
    <legend class="service-form-legend">Your Vehicle</legend>
    <p class="service-form-hint" style="margin:0 0 0.9rem;">Enter your car's details — all fields are optional.</p>

    <div class="service-form-row-3">
      <div class="service-form-group">
        <label class="service-form-label" for="car_year">Year</label>
        <input type="text" name="car_year" id="car_year"
               class="service-form-input"
               maxlength="10"
               placeholder="e.g. 2019"
               value="<%= typeof old !== 'undefined' ? (old.car_year || '') : '' %>">
      </div>
      <div class="service-form-group">
        <label class="service-form-label" for="car_make">Make</label>
        <input type="text" name="car_make" id="car_make"
               class="service-form-input"
               maxlength="100"
               placeholder="e.g. Honda"
               value="<%= typeof old !== 'undefined' ? (old.car_make || '') : '' %>">
      </div>
      <div class="service-form-group">
        <label class="service-form-label" for="car_model">Model</label>
        <input type="text" name="car_model" id="car_model"
               class="service-form-input"
               maxlength="100"
               placeholder="e.g. Civic"
               value="<%= typeof old !== 'undefined' ? (old.car_model || '') : '' %>">
      </div>
    </div>
  </fieldset>

  <!-- Service type -->
  <div class="service-form-group">
    <label class="service-form-label" for="service_type">
      Service Type <span style="color:#dc2626;">*</span>
    </label>
    <select name="service_type" id="service_type" class="service-form-select" required>
      <option value="">-- Select a service type --</option>
      <% const types = [
        "Oil Change", "Tire Rotation", "Brake Inspection", "Engine Tune-Up",
        "Transmission Service", "Battery Replacement", "AC Service",
        "Wheel Alignment", "Multi-Point Inspection", "Other"
      ]; %>
      <% types.forEach(t => { %>
        <option value="<%= t %>"
          <%= (typeof old !== "undefined" && old.service_type === t) ? "selected" : "" %>>
          <%= t %>
        </option>
      <% }) %>
    </select>
  </div>

  <!-- "Other" custom service type — shown by JS when "Other" is selected -->
  <div class="service-form-group" id="other-service-group" style="display:none;">
    <label class="service-form-label" for="other_service_type">
      Describe the service <span style="color:#dc2626;">*</span>
    </label>
    <input type="text" name="other_service_type" id="other_service_type"
           class="service-form-input"
           maxlength="200"
           placeholder="e.g. Windshield wiper replacement"
           value="<%= typeof old !== 'undefined' ? (old.other_service_type || '') : '' %>">
  </div>

  <!-- Description -->
  <div class="service-form-group">
    <label class="service-form-label" for="description">
      Description
      <span class="service-form-hint">Describe the issue or what needs attention</span>
    </label>
    <textarea name="description" id="description" rows="5"
              class="service-form-textarea"
              placeholder="e.g. Engine makes a knocking noise when accelerating at highway speed…"><%= typeof old !== "undefined" ? old.description : "" %></textarea>
  </div>

  <div class="service-form-actions">
    <button type="submit" class="btn btn-primary">Submit Request</button>
    <a href="/service/my-requests" class="btn btn-outline-dark">Cancel</a>
  </div>

</form>

<script>
  (function () {
    var select = document.getElementById('service_type');
    var otherGroup = document.getElementById('other-service-group');
    var otherInput = document.getElementById('other_service_type');

    function toggle() {
      var isOther = select.value === 'Other';
      otherGroup.style.display = isOther ? 'block' : 'none';
      otherInput.required = isOther;
    }

    select.addEventListener('change', toggle);
    toggle(); // set initial state on page load (handles validation re-render)
  })();
</script>

<%- include("../partials/footer") %>

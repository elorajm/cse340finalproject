<%- include("../partials/header") %>

<div class="admin-page-header">
  <h1 class="page-title"><%= title %></h1>
</div>

<p style="color:#6b7280; margin-bottom:1.5rem;">
  <% if (vehicle) { %>
    Editing your review for
    <strong><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></strong>
    &mdash; <a href="/vehicle/<%= vehicle.vehicle_id %>" style="color:#0f4c81; text-decoration:none;">view vehicle</a>
  <% } else { %>
    Editing your general review.
  <% } %>
</p>

<% if (errors.length > 0) { %>
  <div class="form-errors">
    <ul style="margin:0; padding-left:1.2rem;">
      <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
    </ul>
  </div>
<% } %>

<form action="/reviews/edit/<%= review.review_id %>" method="POST" class="service-form">

  <div class="service-form-group">
    <label class="service-form-label" for="rating">Your Rating</label>
    <select name="rating" id="rating" class="service-form-select review-rating-select">
      <%
        const ratingLabels = [
          '',
          '&#9733;&#9734;&#9734;&#9734;&#9734; &mdash; Terrible',
          '&#9733;&#9733;&#9734;&#9734;&#9734; &mdash; Poor',
          '&#9733;&#9733;&#9733;&#9734;&#9734; &mdash; Okay',
          '&#9733;&#9733;&#9733;&#9733;&#9734; &mdash; Good',
          '&#9733;&#9733;&#9733;&#9733;&#9733; &mdash; Excellent'
        ];
      %>
      <% [5,4,3,2,1].forEach(function(n) { %>
        <option value="<%= n %>" <%= review.rating == n ? 'selected' : '' %>><%- ratingLabels[n] %></option>
      <% }) %>
    </select>
  </div>

  <div class="service-form-group">
    <label class="service-form-label" for="comment">
      Your Review
      <span class="service-form-hint">Minimum 10 characters</span>
    </label>
    <textarea name="comment" id="comment" rows="5"
              class="service-form-textarea"><%= review.comment %></textarea>
  </div>

  <div class="service-form-actions">
    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a href="<%= vehicle ? '/vehicle/' + vehicle.vehicle_id : '/reviews' %>" class="btn btn-outline-dark">Cancel</a>
  </div>

</form>

<%- include("../partials/footer") %>

<%- include("../partials/header") %>

<div class="admin-page-header">
  <div>
    <h1 class="page-title">Send Promotion / Coupon</h1>
    <p class="page-subtitle">Create an offer and deliver it directly to your customers' dashboards.</p>
  </div>
  <a href="/admin/promotions" class="btn btn-secondary btn-sm">View History</a>
</div>

<% if (errors.length > 0) { %>
  <div class="form-error-list">
    <% errors.forEach(e => { %><p class="form-error-item"><%= e.msg %></p><% }) %>
  </div>
<% } %>

<div class="form-card" style="max-width:720px; margin: 0 auto 3rem;">
  <form action="/admin/promotions/new" method="POST" novalidate>

    <div class="form-group">
      <label class="form-label" for="title">Promotion Title <span class="req">*</span></label>
      <input
        type="text"
        id="title"
        name="title"
        class="form-input"
        maxlength="200"
        placeholder="e.g. Summer Service Special"
        value="<%= old.title || '' %>"
        required
      >
    </div>

    <div class="form-group">
      <label class="form-label" for="message">Message <span class="req">*</span></label>
      <textarea
        id="message"
        name="message"
        class="form-input"
        rows="5"
        placeholder="Describe the offer in detail..."
        required
      ><%= old.message || '' %></textarea>
    </div>

    <div class="form-row-2">
      <div class="form-group">
        <label class="form-label" for="discount_code">Discount Code <span class="form-optional">(optional)</span></label>
        <input
          type="text"
          id="discount_code"
          name="discount_code"
          class="form-input"
          maxlength="50"
          placeholder="e.g. SUMMER20"
          value="<%= old.discount_code || '' %>"
        >
      </div>
      <div class="form-group">
        <label class="form-label" for="expires_at">Expires On <span class="form-optional">(optional)</span></label>
        <input
          type="date"
          id="expires_at"
          name="expires_at"
          class="form-input"
          value="<%= old.expires_at || '' %>"
        >
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Send To</label>
      <div class="promo-target-options">
        <label class="promo-target-option">
          <input
            type="radio"
            name="target"
            value="all"
            class="promo-target-radio"
            <%= (!old.target || old.target === 'all') ? 'checked' : '' %>
          >
          <span>All registered users (<%= users.length %> accounts)</span>
        </label>
        <label class="promo-target-option">
          <input
            type="radio"
            name="target"
            value="selected"
            class="promo-target-radio"
            <%= old.target === 'selected' ? 'checked' : '' %>
          >
          <span>Select specific users</span>
        </label>
      </div>
    </div>

    <div class="promo-user-list" id="promo-user-list">
      <p class="promo-user-list-hint">Check the users who should receive this offer:</p>
      <div class="promo-user-checkboxes">
        <% users.forEach(u => { %>
          <label class="promo-user-checkbox-label">
            <input
              type="checkbox"
              name="user_ids"
              value="<%= u.user_id %>"
              class="promo-user-checkbox"
            >
            <span class="promo-user-name"><%= u.first_name %> <%= u.last_name %></span>
            <span class="promo-user-email"><%= u.email %></span>
            <span class="role-badge role-<%= u.role %>" style="font-size:0.7rem;"><%= u.role %></span>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="form-actions">
      <a href="/admin/owner" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary">Send Promotion</button>
    </div>

  </form>
</div>

<script>
  (function () {
    var radios     = document.querySelectorAll('.promo-target-radio');
    var userList   = document.getElementById('promo-user-list');

    function updateVisibility() {
      var val = document.querySelector('.promo-target-radio:checked')?.value;
      userList.style.display = val === 'selected' ? 'block' : 'none';
    }

    radios.forEach(function (r) { r.addEventListener('change', updateVisibility); });
    updateVisibility();
  })();
</script>

<%- include("../partials/footer") %>

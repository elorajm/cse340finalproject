<%- include("../partials/header") %>

<h1>Manage Vehicles</h1>

<p><a href="/admin/vehicles/new">+ Add New Vehicle</a></p>

<% if (vehicles.length === 0) { %>
  <p>No vehicles in inventory.</p>
<% } else { %>
  <table style="border-collapse:collapse; width:100%;">
    <thead>
      <tr>
        <th style="text-align:left; padding:8px; border-bottom:1px solid #ccc;">Year</th>
        <th style="text-align:left; padding:8px; border-bottom:1px solid #ccc;">Make</th>
        <th style="text-align:left; padding:8px; border-bottom:1px solid #ccc;">Model</th>
        <th style="text-align:left; padding:8px; border-bottom:1px solid #ccc;">Category</th>
        <th style="text-align:right; padding:8px; border-bottom:1px solid #ccc;">Price</th>
        <th style="text-align:right; padding:8px; border-bottom:1px solid #ccc;">Mileage</th>
        <th style="padding:8px; border-bottom:1px solid #ccc;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% vehicles.forEach(v => { %>
        <tr>
          <td style="padding:8px;"><%= v.year %></td>
          <td style="padding:8px;"><%= v.make %></td>
          <td style="padding:8px;"><%= v.model %></td>
          <td style="padding:8px;"><%= v.category || "—" %></td>
          <td style="padding:8px; text-align:right;">$<%= Number(v.price).toLocaleString() %></td>
          <td style="padding:8px; text-align:right;"><%= Number(v.mileage).toLocaleString() %></td>
          <td style="padding:8px;">
            <a href="/admin/vehicles/edit/<%= v.vehicle_id %>">Edit</a>
            &nbsp;
            <form action="/admin/vehicles/delete/<%= v.vehicle_id %>" method="POST"
                  style="display:inline;"
                  onsubmit="return confirm('Delete <%= v.year %> <%= v.make %> <%= v.model %>?')">
              <button type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include("../partials/footer") %>

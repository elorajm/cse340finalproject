<%- include("../partials/header") %>

<div class="admin-page-header">
  <h1 class="page-title">Manage Vehicles</h1>
  <a href="/admin/vehicles/new" class="btn btn-primary btn-sm">+ Add Vehicle</a>
</div>

<% if (vehicles.length === 0) { %>
  <p>No vehicles in inventory yet.</p>
<% } else { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Year</th>
        <th>Make</th>
        <th>Model</th>
        <th>Category</th>
        <th style="text-align:right;">Price</th>
        <th style="text-align:right;">Mileage</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% vehicles.forEach(v => { %>
        <tr>
          <td><%= v.year %></td>
          <td><%= v.make %></td>
          <td><%= v.model %></td>
          <td><%= v.category || "—" %></td>
          <td style="text-align:right;">$<%= Number(v.price).toLocaleString() %></td>
          <td style="text-align:right;"><%= Number(v.mileage).toLocaleString() %></td>
          <td>
            <div class="admin-table-actions">
              <a href="/admin/vehicles/edit/<%= v.vehicle_id %>" class="btn btn-sm">Edit</a>
              <form action="/admin/vehicles/delete/<%= v.vehicle_id %>" method="POST"
                    onsubmit="return confirm('Delete <%= v.year %> <%= v.make %> <%= v.model %>?')">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include("../partials/footer") %>

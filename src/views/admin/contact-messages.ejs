<%- include("../partials/header") %>

<div class="admin-page-header">
  <h1 class="page-title"><%= title %></h1>
  <span style="color:#6b7280; font-size:0.9rem;"><%= messages.length %> message<%= messages.length !== 1 ? 's' : '' %></span>
</div>

<% if (messages.length === 0) { %>
  <p style="color:#6b7280;">No contact messages yet.</p>
<% } else { %>
  <div class="messages-list">
    <% messages.forEach(m => { %>
      <article class="message-card">
        <div class="msg-card-header">
          <h3 class="msg-card-subject"><%= m.subject %></h3>
          <time class="msg-card-time"><%= new Date(m.created_at).toLocaleString() %></time>
        </div>
        <p class="msg-card-from">
          From <strong><%= m.name %></strong>
          &mdash; <a href="mailto:<%= m.email %>"><%= m.email %></a>
        </p>
        <p class="msg-card-body"><%= m.message %></p>
      </article>
    <% }) %>
  </div>
<% } %>

<%- include("../partials/footer") %>

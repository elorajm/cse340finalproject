<%- include("../partials/header") %>

<div class="dashboard-header">
  <div>
    <h1 class="page-title" style="margin-bottom:0.25rem;">
      <%= user.role === 'owner' ? 'User Dashboard' : 'My Account' %>
    </h1>
    <p style="color:#6b7280; margin:0;">Welcome back, <%= user.first_name %>.</p>
  </div>
</div>

<!-- Owner only: Registered Users + Promotion Tools -->
<% if (user.role === 'owner' && allUsers) { %>
  <h2 class="dashboard-section-title">
    Registered Users
    <span class="promo-unread-badge" style="background:#f59e0b;"><%= allUsers.length %></span>
  </h2>

  <div class="owner-users-toolbar">
    <a href="/admin/promotions/new" class="btn btn-primary">Send Promotion / Coupon</a>
    <a href="/admin/users" class="btn btn-secondary">Manage Roles</a>
  </div>

  <div class="owner-users-table-wrap">
    <table class="owner-users-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Joined</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% allUsers.forEach(function(u) { %>
          <tr>
            <td class="ou-name"><%= u.first_name %> <%= u.last_name %></td>
            <td class="ou-email"><%= u.email %></td>
            <td><span class="role-badge role-<%= u.role %>"><%= u.role %></span></td>
            <td class="ou-date"><%= new Date(u.created_at).toLocaleDateString() %></td>
            <td>
              <a href="/admin/promotions/new" class="btn btn-xs btn-outline">
                Send Offer
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<!-- Account info card -->
<div class="user-info-card">
  <div class="user-info-avatar"><%= user.first_name.charAt(0).toUpperCase() %><%= (user.last_name || '?').charAt(0).toUpperCase() %></div>
  <div class="user-info-body">
    <div class="user-info-name"><%= user.first_name %> <%= user.last_name || '' %></div>
    <div class="user-info-email"><%= user.email %></div>
    <div style="margin-top:0.4rem;">
      <span class="role-badge role-<%= user.role %>"><%= user.role %></span>
    </div>
  </div>
  <div class="user-info-meta">
    <div class="user-info-stat">
      <span class="user-info-stat-num"><%= serviceRequests.length %></span>
      <span class="user-info-stat-label">Service Requests</span>
    </div>
    <div class="user-info-stat">
      <span class="user-info-stat-num"><%= reviews.length %></span>
      <span class="user-info-stat-label">Reviews</span>
    </div>
  </div>
</div>

<!-- Quick actions -->
<h2 class="dashboard-section-title">Quick Actions</h2>
<div class="dashboard-grid" style="margin-bottom:2rem;">

  <a href="/service/new" class="dash-card">
    <span class="dash-card-icon">&#128296;</span>
    <div class="dash-card-body">
      <h3>Request Service</h3>
      <p>Submit a new vehicle service request.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

  <a href="/inventory" class="dash-card">
    <span class="dash-card-icon">&#11088;</span>
    <div class="dash-card-body">
      <h3>Leave a Review</h3>
      <p>Browse inventory and review a vehicle you own.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

  <a href="/service/my-requests" class="dash-card">
    <span class="dash-card-icon">&#128196;</span>
    <div class="dash-card-body">
      <h3>All My Requests</h3>
      <p>View the full history of your service requests.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

  <a href="#wishlist" class="dash-card">
    <span class="dash-card-icon">&#10084;</span>
    <div class="dash-card-body">
      <h3>My Wish List</h3>
      <p><%= wishlist.length %> saved vehicle<%= wishlist.length !== 1 ? 's' : '' %>.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

</div>

<!-- Wish List -->
<h2 class="dashboard-section-title" id="wishlist" style="margin-top:2rem;">
  &#10084; My Wish List
  <% if (wishlist.length > 0) { %>
    <span class="promo-unread-badge" style="background:#e11d48;"><%= wishlist.length %></span>
  <% } %>
</h2>
<% if (wishlist.length === 0) { %>
  <div class="user-empty-state">
    <p>You haven't saved any vehicles yet. Click the heart on any vehicle to add it here.</p>
    <a href="/inventory" class="btn btn-primary btn-sm">Browse Inventory</a>
  </div>
<% } else { %>
  <div class="wishlist-grid">
    <% wishlist.forEach(function(v) { %>
      <a href="/vehicle/<%= v.vehicle_id %>" class="wishlist-card">
        <div class="wishlist-card-img-wrap">
          <img src="<%= v.image_url %>" alt="<%= v.alt_text %>" class="wishlist-card-img">
        </div>
        <div class="wishlist-card-body">
          <div class="wishlist-card-title"><%= v.year %> <%= v.make %> <%= v.model %></div>
          <div class="wishlist-card-price">$<%= Number(v.price).toLocaleString() %></div>
          <div class="wishlist-card-mileage"><%= Number(v.mileage).toLocaleString() %> mi</div>
        </div>
        <span class="wishlist-card-heart">&#10084;</span>
      </a>
    <% }) %>
  </div>
<% } %>

<!-- Service requests summary -->
<h2 class="dashboard-section-title">Recent Service Requests</h2>
<% if (serviceRequests.length === 0) { %>
  <div class="user-empty-state">
    <p>You haven't submitted any service requests yet.</p>
    <a href="/service/new" class="btn btn-primary btn-sm">Request Service</a>
  </div>
<% } else { %>
  <div class="user-request-list">
    <% serviceRequests.slice(0, 5).forEach(r => { %>
      <div class="user-request-row">
        <div class="user-request-main">
          <span class="service-status-badge service-status-<%= r.status.toLowerCase().replace(/ /g, '-') %>">
            <%= r.status %>
          </span>
          <span class="user-request-type"><%= r.service_type %></span>
          <% if (r.car_year || r.car_make || r.car_model) { %>
            <span class="user-request-vehicle">&mdash; <%= [r.car_year, r.car_make, r.car_model].filter(Boolean).join(' ') %></span>
          <% } %>
        </div>
        <time class="user-request-date"><%= new Date(r.created_at).toLocaleDateString() %></time>
      </div>
      <% if (r.notes) { %>
        <p class="user-request-notes">Staff note: <em><%= r.notes %></em></p>
      <% } %>
    <% }) %>
  </div>
  <% if (serviceRequests.length > 5) { %>
    <p style="margin-top:0.75rem; font-size:0.88rem;">
      <a href="/service/my-requests" style="color:#0f4c81;">View all <%= serviceRequests.length %> requests &rarr;</a>
    </p>
  <% } %>
<% } %>

<!-- Reviews summary -->
<h2 class="dashboard-section-title" style="margin-top:2rem;">My Reviews</h2>
<% if (reviews.length === 0) { %>
  <div class="user-empty-state">
    <p>You haven't written any reviews yet.</p>
    <a href="/inventory" class="btn btn-primary btn-sm">Browse Inventory</a>
  </div>
<% } else { %>
  <div class="user-review-list">
    <% reviews.forEach(rev => { %>
      <div class="user-review-row">
        <div class="user-review-vehicle">
          <a href="/vehicle/<%= rev.vehicle_id %>" style="color:#111827; font-weight:600; text-decoration:none;">
            <%= rev.year %> <%= rev.make %> <%= rev.model %>
          </a>
        </div>
        <div class="user-review-stars">
          <% for (let i = 1; i <= 5; i++) { %>
            <span style="color: <%= i <= rev.rating ? '#f59e0b' : '#d1d5db' %>;">&#9733;</span>
          <% } %>
        </div>
        <% if (rev.comment) { %>
          <p class="user-review-comment"><%= rev.comment %></p>
        <% } %>
        <time class="user-request-date"><%= new Date(rev.created_at).toLocaleDateString() %></time>
      </div>
    <% }) %>
  </div>
<% } %>

<!-- Promotions inbox -->
<h2 class="dashboard-section-title" style="margin-top:2rem;">
  Promotions &amp; Offers
  <% const unread = promotions.filter(p => !p.is_read); %>
  <% if (unread.length > 0) { %>
    <span class="promo-unread-badge"><%= unread.length %> new</span>
  <% } %>
</h2>

<% if (promotions.length === 0) { %>
  <div class="user-empty-state">
    <p>You have no promotions or offers at this time.</p>
  </div>
<% } else { %>
  <div class="promo-inbox">
    <% promotions.forEach(function(p) { %>
      <div class="promo-inbox-card <%= p.is_read ? 'promo-read' : 'promo-unread' %>">

        <div class="promo-inbox-header">
          <div class="promo-inbox-header-left">
            <% if (!p.is_read) { %><span class="promo-new-dot" aria-label="New"></span><% } %>
            <h3 class="promo-inbox-title"><%= p.title %></h3>
          </div>
          <time class="msg-card-time" datetime="<%= p.received_at %>">
            <%= new Date(p.received_at).toLocaleDateString() %>
          </time>
        </div>

        <p class="promo-inbox-message"><%= p.message %></p>

        <% if (p.discount_code) { %>
          <div class="promo-code-block">
            Use code: <strong class="promo-code-text"><%= p.discount_code %></strong>
          </div>
        <% } %>

        <% if (p.expires_at) { %>
          <p class="promo-expires">
            Offer expires: <strong><%= new Date(p.expires_at).toLocaleDateString() %></strong>
          </p>
        <% } %>

        <% if (!p.is_read) { %>
          <form action="/admin/promotions/<%= p.promotion_id %>/dismiss" method="POST" style="margin-top:0.75rem;">
            <button type="submit" class="btn btn-sm btn-secondary">Dismiss</button>
          </form>
        <% } %>

      </div>
    <% }) %>
  </div>
<% } %>

<%- include("../partials/footer") %>

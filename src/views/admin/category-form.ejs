<%- include("../partials/header") %>

<h1 class="page-title"><%= title %></h1>

<% if (errors && errors.length > 0) { %>
  <ul class="form-errors">
    <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
  </ul>
<% } %>

<% const action = category
     ? `/admin/categories/edit/${category.category_id}`
     : "/admin/categories/new"; %>

<form action="<%= action %>" method="POST" style="max-width:400px;">
  <p>
    <label for="name">Category Name <span style="color:red;">*</span></label><br>
    <input type="text" id="name" name="name" required
           value="<%= old.name || '' %>"
           style="width:100%; padding:0.6rem; border:1px solid #ccc; border-radius:6px; font-size:1rem;">
  </p>

  <div style="display:flex; gap:0.75rem; margin-top:1rem;">
    <button type="submit" class="btn btn-primary">
      <%= category ? "Save Changes" : "Add Category" %>
    </button>
    <a href="/admin/categories" class="btn btn-sm" style="background:#eee; color:#333; display:flex; align-items:center;">Cancel</a>
  </div>
</form>

<%- include("../partials/footer") %>

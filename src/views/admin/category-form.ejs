<%- include("../partials/header") %>

<div class="admin-page-header">
  <h1 class="page-title"><%= title %></h1>
  <a href="/admin/categories" class="btn btn-outline-dark btn-sm-outline">&#8592; Back to Categories</a>
</div>

<% if (errors && errors.length > 0) { %>
  <div class="form-errors">
    <ul style="margin:0; padding-left:1.2rem;">
      <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
    </ul>
  </div>
<% } %>

<% const action = category
     ? `/admin/categories/edit/${category.category_id}`
     : "/admin/categories/new"; %>

<form action="<%= action %>" method="POST" class="service-form">

  <div class="service-form-group">
    <label class="service-form-label" for="name">
      Category Name <span style="color:#dc2626;">*</span>
      <span class="service-form-hint">Used to group vehicles in inventory (e.g. SUV, Truck, Sedan)</span>
    </label>
    <input type="text" id="name" name="name" required
           value="<%= old.name || '' %>"
           class="service-form-select"
           placeholder="e.g. SUV">
  </div>

  <div class="service-form-actions">
    <button type="submit" class="btn btn-primary">
      <%= category ? "Save Changes" : "Add Category" %>
    </button>
    <a href="/admin/categories" class="btn btn-outline-dark">Cancel</a>
  </div>

</form>

<%- include("../partials/footer") %>

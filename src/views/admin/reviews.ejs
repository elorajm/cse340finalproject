<%- include("../partials/header") %>

<div class="admin-page-header">
  <h1 class="page-title"><%= title %></h1>
  <span style="color:#6b7280; font-size:0.9rem;"><%= reviews.length %> review<%= reviews.length !== 1 ? 's' : '' %></span>
</div>

<% if (reviews.length === 0) { %>
  <p style="color:#6b7280;">No reviews yet.</p>
<% } else { %>
  <div class="messages-list">
    <% reviews.forEach(function(review) { %>
      <article class="message-card review-mod-card">
        <div class="review-mod-header">
          <div>
            <strong><%= review.first_name %> <%= review.last_name %></strong>
            <% if (review.year) { %>
              <span style="color:#6b7280;"> reviewed </span>
              <strong><%= review.year %> <%= review.make %> <%= review.model %></strong>
            <% } else { %>
              <span style="color:#6b7280;"> — General Review</span>
            <% } %>
          </div>
          <div class="review-mod-meta">
            <span class="review-stars">
              <% for (let i = 1; i <= 5; i++) { %>
                <span style="color: <%= i <= review.rating ? '#f59e0b' : '#d1d5db' %>;">&#9733;</span>
              <% } %>
            </span>
            <time style="color:#9ca3af; font-size:0.82rem;"><%= new Date(review.created_at).toLocaleDateString() %></time>
          </div>
        </div>
        <p class="review-mod-comment"><%= review.comment %></p>
        <form action="/reviews/delete/<%= review.review_id %>" method="POST"
              onsubmit="return confirm('Delete this review?')">
          <button type="submit" class="btn btn-sm btn-danger">Delete Review</button>
        </form>
      </article>
    <% }) %>
  </div>
<% } %>

<%- include("../partials/footer") %>

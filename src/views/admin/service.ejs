<%- include("../partials/header") %>

<div class="admin-page-header">
  <h1 class="page-title"><%= title %></h1>
  <span style="color:#6b7280; font-size:0.9rem;"><%= requests.length %> request<%= requests.length !== 1 ? 's' : '' %></span>
</div>

<% if (requests.length === 0) { %>
  <p style="color:#6b7280;">No service requests yet.</p>
<% } else { %>
  <div class="service-list">
    <% requests.forEach(r => { %>
      <div class="service-card">

        <div class="service-card-header">
          <div>
            <span class="service-card-id">#<%= r.request_id %></span>
            <span class="service-card-type"><%= r.service_type %></span>
          </div>
          <span class="service-status-badge service-status-<%= r.status.toLowerCase().replace(/ /g, '-') %>">
            <%= r.status %>
          </span>
        </div>

        <div class="service-card-details">
          <p><strong>Customer:</strong> <%= r.first_name %> <%= r.last_name %></p>
          <p>
            <strong>Vehicle:</strong>
            <% if (r.car_year || r.car_make || r.car_model) { %>
              <%= [r.car_year, r.car_make, r.car_model].filter(Boolean).join(' ') %>
            <% } else { %>
              <em style="color:#9ca3af;">Not specified</em>
            <% } %>
          </p>
          <% if (r.description) { %>
            <p><strong>Description:</strong> <%= r.description %></p>
          <% } %>
          <% if (r.notes) { %>
            <p><strong>Staff notes:</strong> <em><%= r.notes %></em></p>
          <% } %>
          <p style="color:#9ca3af; font-size:0.82rem; margin-top:0.5rem;">
            Submitted <%= new Date(r.created_at).toLocaleDateString() %>
          </p>
        </div>

        <form action="/service/update/<%= r.request_id %>" method="POST" class="service-update-form">
          <label class="service-update-label">
            Status
            <select name="status" class="service-update-select">
              <% ["Submitted", "In Progress", "Completed", "Cancelled"].forEach(s => { %>
                <option value="<%= s %>" <%= r.status === s ? "selected" : "" %>><%= s %></option>
              <% }) %>
            </select>
          </label>
          <label class="service-update-label" style="flex:1; min-width:200px;">
            Staff Notes
            <input name="notes" value="<%= r.notes || '' %>"
                   placeholder="Add or update notes…"
                   class="service-update-input">
          </label>
          <button type="submit" class="btn btn-primary btn-sm" style="align-self:flex-end;">Save</button>
        </form>

      </div>
    <% }) %>
  </div>
<% } %>

<%- include("../partials/footer") %>

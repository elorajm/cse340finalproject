<%- include("../partials/header") %>

<h1>Manage Service Requests</h1>

<% if (requests.length === 0) { %>
  <p>No service requests found.</p>
<% } else { %>
  <% requests.forEach(r => { %>
    <div style="border:1px solid #ccc; padding:12px; margin-bottom:16px;">
      <p><strong>#<%= r.request_id %> — <%= r.service_type %></strong></p>
      <p>
        <strong>Customer:</strong> <%= r.first_name %> <%= r.last_name %>
      </p>
      <p>
        <strong>Vehicle:</strong>
        <% if (r.year && r.make && r.model) { %>
          <%= r.year %> <%= r.make %> <%= r.model %>
        <% } else { %>
          Not specified
        <% } %>
      </p>
      <% if (r.description) { %>
        <p><strong>Description:</strong> <%= r.description %></p>
      <% } %>
      <p><strong>Current Status:</strong> <%= r.status %></p>
      <% if (r.notes) { %>
        <p><strong>Notes:</strong> <%= r.notes %></p>
      <% } %>
      <p><strong>Submitted:</strong> <%= new Date(r.created_at).toLocaleDateString() %></p>

      <form action="/service/update/<%= r.request_id %>" method="POST">
        <label>Update Status:
          <select name="status">
            <% ["Submitted", "In Progress", "Completed"].forEach(s => { %>
              <option value="<%= s %>" <%= r.status === s ? "selected" : "" %>><%= s %></option>
            <% }) %>
          </select>
        </label>
        <label> Notes:
          <input name="notes" value="<%= r.notes || "" %>" placeholder="Staff notes">
        </label>
        <button type="submit">Update</button>
      </form>
    </div>
  <% }) %>
<% } %>

<%- include("../partials/footer") %>

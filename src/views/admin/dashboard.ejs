<%- include("../partials/header") %>

<div class="dashboard-header">
  <div>
    <h1 class="page-title" style="margin-bottom:0.25rem;">Owner Dashboard</h1>
    <p style="color:#6b7280; margin:0;">Welcome back, <%= user.first_name %>. Here's an overview of the dealership.</p>
  </div>
</div>

<!-- Stats row -->
<div class="stats-row">
  <div class="stat-card">
    <span class="stat-icon">&#128664;</span>
    <div>
      <div class="stat-number"><%= stats.vehicles %></div>
      <div class="stat-label">Vehicles</div>
    </div>
  </div>
  <div class="stat-card">
    <span class="stat-icon">&#128194;</span>
    <div>
      <div class="stat-number"><%= stats.categories %></div>
      <div class="stat-label">Categories</div>
    </div>
  </div>
  <div class="stat-card">
    <span class="stat-icon">&#128101;</span>
    <div>
      <div class="stat-number"><%= stats.users %></div>
      <div class="stat-label">Users</div>
    </div>
  </div>
  <div class="stat-card stat-card-alert">
    <span class="stat-icon">&#128296;</span>
    <div>
      <div class="stat-number"><%= stats.pendingServices %></div>
      <div class="stat-label">Pending Service</div>
    </div>
  </div>
  <div class="stat-card">
    <span class="stat-icon">&#128172;</span>
    <div>
      <div class="stat-number"><%= stats.messages %></div>
      <div class="stat-label">Messages</div>
    </div>
  </div>
  <div class="stat-card">
    <span class="stat-icon">&#11088;</span>
    <div>
      <div class="stat-number"><%= stats.reviews %></div>
      <div class="stat-label">Reviews</div>
    </div>
  </div>
</div>

<!-- Management cards -->
<h2 class="dashboard-section-title">Inventory</h2>
<div class="dashboard-grid">

  <a href="/admin/vehicles" class="dash-card">
    <span class="dash-card-icon">&#128664;</span>
    <div class="dash-card-body">
      <h3>Vehicles</h3>
      <p>Add, edit, or remove vehicles from the lot. <%= stats.vehicles %> listed.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

  <a href="/admin/categories" class="dash-card">
    <span class="dash-card-icon">&#128194;</span>
    <div class="dash-card-body">
      <h3>Categories</h3>
      <p>Organise vehicles into categories. <%= stats.categories %> active.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

</div>

<h2 class="dashboard-section-title">Operations</h2>
<div class="dashboard-grid">

  <a href="/service/admin" class="dash-card">
    <span class="dash-card-icon">&#128296;</span>
    <div class="dash-card-body">
      <h3>Service Requests</h3>
      <p><%= stats.pendingServices %> pending &middot; <%= stats.totalServices %> total.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

  <a href="/contact/messages" class="dash-card">
    <span class="dash-card-icon">&#128172;</span>
    <div class="dash-card-body">
      <h3>Contact Messages</h3>
      <p><%= stats.messages %> message<%= stats.messages !== 1 ? 's' : '' %> received.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

  <a href="/admin/reviews" class="dash-card">
    <span class="dash-card-icon">&#11088;</span>
    <div class="dash-card-body">
      <h3>Review Moderation</h3>
      <p>Read and remove customer reviews. <%= stats.reviews %> total.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

</div>

<h2 class="dashboard-section-title">
  People
  <span class="promo-unread-badge" style="background:#f59e0b;"><%= allUsers.length %></span>
</h2>
<div class="owner-users-toolbar">
  <a href="/admin/promotions/new" class="btn btn-primary">Send Promotion / Coupon</a>
  <a href="/admin/users" class="btn btn-secondary">Manage Roles</a>
</div>
<div class="owner-users-table-wrap">
  <table class="owner-users-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Joined</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% allUsers.forEach(function(u) { %>
        <tr>
          <td class="ou-name"><%= u.first_name %> <%= u.last_name %></td>
          <td class="ou-email"><%= u.email %></td>
          <td><span class="role-badge role-<%= u.role %>"><%= u.role %></span></td>
          <td class="ou-date"><%= new Date(u.created_at).toLocaleDateString() %></td>
          <td>
            <a href="/admin/promotions/new" class="btn btn-xs btn-outline">Send Offer</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<h2 class="dashboard-section-title">Marketing</h2>
<div class="dashboard-grid">

  <a href="/admin/promotions/new" class="dash-card dash-card-highlight">
    <span class="dash-card-icon">&#127881;</span>
    <div class="dash-card-body">
      <h3>Send Promotion</h3>
      <p>Create and send a coupon or special offer directly to customers' dashboards.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

  <a href="/admin/promotions" class="dash-card">
    <span class="dash-card-icon">&#128220;</span>
    <div class="dash-card-body">
      <h3>Promotion History</h3>
      <p>Review all offers and promotions you've sent.</p>
    </div>
    <span class="dash-card-arrow">&#8250;</span>
  </a>

</div>

<h2 class="dashboard-section-title">Customer Wishlists</h2>
<% if (customerWishlists.length === 0) { %>
  <p style="color:#6b7280; margin-bottom:2rem;">No customers have saved any vehicles yet.</p>
<% } else { %>
  <div class="owner-wishlist-section">
    <% customerWishlists.forEach(function(customer) { %>
      <div class="owner-wishlist-user">
        <div class="owner-wishlist-user-header">
          <span>&#9825;</span>
          <strong><%= customer.first_name %> <%= customer.last_name %></strong>
          <span style="color:#6b7280; font-size:0.85rem;"><%= customer.email %></span>
          <span class="owner-wishlist-count"><%= customer.vehicles.length %> saved</span>
        </div>
        <div class="owner-wishlist-vehicles">
          <% customer.vehicles.forEach(function(v) { %>
            <a href="/vehicle/<%= v.vehicle_id %>" class="owner-wishlist-vehicle">
              <img src="<%= v.image_url %>" alt="<%= v.alt_text %>" class="owner-wishlist-img" onerror="this.src='/images/no-image.jpg'">
              <div class="owner-wishlist-vehicle-info">
                <span class="owner-wishlist-vehicle-name"><%= v.year %> <%= v.make %> <%= v.model %></span>
                <span class="owner-wishlist-vehicle-price">$<%= Number(v.price).toLocaleString() %></span>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include("../partials/footer") %>

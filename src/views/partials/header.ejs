<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== "undefined" ? title + " | Jake's Car Dealership" : "Jake's Car Dealership" %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">

<header class="site-header">
  <div class="site-header-inner">

    <a href="/" class="site-brand">Jake's Car Dealership</a>

    <nav class="main-nav" aria-label="Main navigation">

      <%
        function navActive(paths) {
          if (!Array.isArray(paths)) paths = [paths];
          return paths.some(p =>
            typeof p === 'object'
              ? currentPath.startsWith(p.startsWith)
              : currentPath === p
          ) ? 'nav-active' : '';
        }
      %>

      <!-- Public links — always visible -->
      <div class="nav-group nav-public">
        <a href="/"         class="nav-link <%= navActive('/') %>">Home</a>
        <a href="/inventory" class="nav-link <%= navActive([{startsWith:'/inventory'},{startsWith:'/vehicle'}]) %>">Inventory</a>
        <a href="/contact"   class="nav-link <%= navActive('/contact') %>">Contact</a>
      </div>

      <% if (user) { %>

        <span class="nav-divider" aria-hidden="true"></span>

        <!-- User-specific links -->
        <div class="nav-group nav-user">
          <a href="/service/my-requests"
             class="nav-link <%= navActive({startsWith:'/service/my'}) %>">My&nbsp;Service&nbsp;Requests</a>

          <a href="/admin/dashboard"
             class="nav-link <%= navActive('/admin/dashboard') %>">Dashboard</a>

          <% if (user.role === "employee" || user.role === "owner") { %>
            <a href="/admin/employee"
               class="nav-link nav-role-link <%= navActive('/admin/employee') %>">Employee&nbsp;Panel</a>
          <% } %>

          <% if (user.role === "owner") { %>
            <a href="/admin/owner"
               class="nav-link nav-role-link nav-owner-link <%= navActive('/admin/owner') %>">Owner&nbsp;Panel</a>
          <% } %>
        </div>

        <span class="nav-divider" aria-hidden="true"></span>

        <!-- User meta -->
        <div class="nav-group nav-meta">
          <span class="nav-welcome">Hi, <%= user.first_name %></span>
          <form action="/auth/logout" method="POST" style="margin:0;">
            <button type="submit" class="nav-logout-btn">Logout</button>
          </form>
        </div>

      <% } else { %>

        <span class="nav-divider" aria-hidden="true"></span>

        <!-- Guest auth links -->
        <div class="nav-group nav-auth">
          <a href="/auth/login"    class="nav-link <%= navActive('/auth/login') %>">Login</a>
          <a href="/auth/register" class="nav-register-btn">Register</a>
        </div>

      <% } %>

    </nav>
  </div>
</header>

<main>

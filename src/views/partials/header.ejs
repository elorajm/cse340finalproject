<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== "undefined" ? title + " | Jake's Car Dealership" : "Jake's Car Dealership" %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">

<header class="site-header">
  <div class="site-header-inner">

    <a href="/" class="site-brand">Jake's Car Dealership</a>

    <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle navigation" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="main-nav" id="main-nav" aria-label="Main navigation">

      <%
        function navActive(paths) {
          if (!Array.isArray(paths)) paths = [paths];
          return paths.some(p =>
            typeof p === 'object'
              ? currentPath.startsWith(p.startsWith)
              : currentPath === p
          ) ? 'nav-active' : '';
        }
      %>

      <!-- Public links — always visible -->
      <div class="nav-group nav-public">
        <a href="/"         class="nav-link <%= navActive('/') %>">Home</a>
        <a href="/inventory" class="nav-link <%= navActive([{startsWith:'/inventory'},{startsWith:'/vehicle'}]) %>">Inventory</a>
        <a href="/reviews"   class="nav-link <%= navActive({startsWith:'/reviews'}) %>">Reviews</a>
        <a href="/contact"   class="nav-link <%= navActive('/contact') %>">Contact</a>
      </div>

      <% if (user) { %>

        <span class="nav-divider" aria-hidden="true"></span>

        <!-- User-specific links -->
        <div class="nav-group nav-user">
          <a href="/service/my-requests"
             class="nav-link <%= navActive({startsWith:'/service/my'}) %>">My&nbsp;Service&nbsp;Requests</a>

          <% if (user.role === "user") { %>
            <a href="/admin/dashboard"
               class="nav-link <%= navActive('/admin/dashboard') %>">Dashboard</a>

          <% } else if (user.role === "employee") { %>
            <a href="/admin/employee"
               class="nav-link <%= navActive('/admin/employee') %>">Dashboard</a>

          <% } else if (user.role === "owner") { %>
            <a href="/admin/dashboard"
               class="nav-link nav-role-link <%= navActive('/admin/dashboard') %>">Personal&nbsp;Dashboard</a>
            <a href="/admin/employee"
               class="nav-link nav-role-link <%= navActive('/admin/employee') %>">Employee&nbsp;Panel</a>
            <a href="/admin/owner"
               class="nav-link nav-role-link nav-owner-link <%= navActive('/admin/owner') %>">Owner&nbsp;Panel</a>
          <% } %>
        </div>

        <span class="nav-divider" aria-hidden="true"></span>

        <!-- User meta -->
        <div class="nav-group nav-meta">
          <span class="nav-welcome">Hi, <%= user.first_name %></span>
          <form action="/auth/logout" method="POST" style="margin:0;">
            <button type="submit" class="nav-logout-btn">Logout</button>
          </form>
        </div>

      <% } else { %>

        <span class="nav-divider" aria-hidden="true"></span>

        <!-- Guest auth links -->
        <div class="nav-group nav-auth">
          <a href="/auth/login"    class="nav-link <%= navActive('/auth/login') %>">Login</a>
          <a href="/auth/register" class="nav-register-btn">Register</a>
        </div>

      <% } %>

    </nav>
  </div>
</header>

<main>

<% if (typeof flash !== 'undefined' && flash.length > 0) { %>
  <div class="flash-container" id="flash-container">
    <% flash.forEach(function(f, i) { %>
      <div class="flash flash-<%= f.type %>" role="alert" id="flash-<%= i %>">
        <span class="flash-msg"><%= f.message %></span>
        <button class="flash-close" aria-label="Dismiss" onclick="this.parentElement.remove()">&#x2715;</button>
      </div>
    <% }); %>
  </div>
<% } %>

<% if (typeof query !== 'undefined' && query.bye === '1') { %>
  <div class="flash-container" id="flash-container-bye">
    <div class="flash flash-info" role="alert">
      <span class="flash-msg">You have been logged out successfully.</span>
      <button class="flash-close" aria-label="Dismiss" onclick="this.parentElement.remove()">&#x2715;</button>
    </div>
  </div>
<% } %>

<script>
  (function() {
    // Auto-dismiss flash messages
    setTimeout(function() {
      ['flash-container','flash-container-bye'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) {
          el.style.transition = 'opacity 0.5s';
          el.style.opacity = '0';
          setTimeout(function() { if (el) el.remove(); }, 500);
        }
      });
    }, 5000);

    // Hamburger menu toggle
    var btn = document.getElementById('nav-hamburger');
    var nav = document.getElementById('main-nav');
    if (btn && nav) {
      btn.addEventListener('click', function() {
        var open = nav.classList.toggle('nav-open');
        btn.setAttribute('aria-expanded', String(open));
        btn.classList.toggle('is-open', open);
      });
      // Close on nav link/button click
      nav.querySelectorAll('a, button').forEach(function(el) {
        el.addEventListener('click', function() {
          nav.classList.remove('nav-open');
          btn.setAttribute('aria-expanded', 'false');
          btn.classList.remove('is-open');
        });
      });
      // Close on outside click
      document.addEventListener('click', function(e) {
        if (!nav.contains(e.target) && !btn.contains(e.target)) {
          nav.classList.remove('nav-open');
          btn.setAttribute('aria-expanded', 'false');
          btn.classList.remove('is-open');
        }
      });
    }
  })();
</script>
